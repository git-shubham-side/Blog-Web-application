<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Create account — ink.cms</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/auth.css" />
</head>
<body>
  <div class="wrap">

    <!-- Left decorative panel -->
    <aside class="left">
      <canvas id="dotCanvas" class="dot-canvas"></canvas>
      <div class="left-inner">
        <div class="logo">ink<span class="logo-dot">.</span>cms</div>

        <div class="left-middle">
          <blockquote>
            "Either write something<br/>worth reading or do<br/>something worth writing."
          </blockquote>
          <cite>— Benjamin Franklin</cite>
        </div>

        <ul class="feat-list">
          <li><span class="dot"></span>Free forever for solo writers</li>
          <li><span class="dot"></span>No credit card required</li>
          <li><span class="dot"></span>Publish in under 5 minutes</li>
          <li><span class="dot"></span>Full markdown + rich text support</li>
        </ul>
      </div>
    </aside>

    <!-- Right form panel -->
    <main class="right">
      <div class="form-box">

        <!-- Tabs -->
        <div class="tabs">
          <a href="/login" class="tab">Sign in</a>
          <a href="/signup" class="tab active">Create account</a>
        </div>

        <h1 class="form-title">Start writing today</h1>
        <p class="form-sub">Create your free account and publish your first post in minutes.</p>

        <!-- Flash messages -->
        <% if (typeof error !== 'undefined' && error) { %>
          <div class="flash flash-error"><%= error %></div>
        <% } %>
        <% if (typeof success !== 'undefined' && success) { %>
          <div class="flash flash-success"><%= success %></div>
        <% } %>

        <form action="/signup" method="POST" id="signupForm" novalidate>

          <div class="field-row-2">
            <div class="field">
              <label for="firstName">First name</label>
              <input
                type="text"
                id="firstName"
                name="firstName"
                placeholder="Arjun"
                value="<%= typeof formData !== 'undefined' ? formData.firstName || '' : '' %>"
                autocomplete="given-name"
              />
              <p class="field-err" id="fname-err">Required.</p>
            </div>
            <div class="field">
              <label for="lastName">Last name</label>
              <input
                type="text"
                id="lastName"
                name="lastName"
                placeholder="Sharma"
                value="<%= typeof formData !== 'undefined' ? formData.lastName || '' : '' %>"
                autocomplete="family-name"
              />
            </div>
          </div>

          <div class="field">
            <label for="email">Email</label>
            <input
              type="email"
              id="email"
              name="email"
              placeholder="you@example.com"
              value="<%= typeof formData !== 'undefined' ? formData.email || '' : '' %>"
              autocomplete="email"
            />
            <p class="field-err" id="email-err">Please enter a valid email address.</p>
          </div>

          <div class="field">
            <label for="username">Username</label>
            <div class="input-prefix-wrap">
              <span class="input-prefix">ink.cms/</span>
              <input
                type="text"
                id="username"
                name="username"
                placeholder="arjun"
                value="<%= typeof formData !== 'undefined' ? formData.username || '' : '' %>"
                autocomplete="username"
                style="border-radius: 0 8px 8px 0;"
              />
            </div>
            <p class="field-err" id="username-err">Username must be 3–20 chars, letters and numbers only.</p>
          </div>

          <div class="field">
            <label for="password">Password</label>
            <div class="input-wrap">
              <input
                type="password"
                id="password"
                name="password"
                placeholder="Min. 8 characters"
                autocomplete="new-password"
              />
              <button type="button" class="eye-btn" onclick="togglePass('password', this)" aria-label="Toggle password">
                <svg class="eye-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
              </button>
            </div>
            <div class="strength-bar" id="strengthBar">
              <div class="strength-fill" id="strengthFill"></div>
            </div>
            <p class="strength-label" id="strengthLabel"></p>
            <p class="field-err" id="pass-err">Must be at least 8 characters.</p>
          </div>

          <!-- Role selector -->
          <div class="field">
            <label>I want to join as</label>
            <div class="role-grid">
              <label class="role-card">
                <input type="radio" name="role" value="reader" checked />
                <span class="role-inner">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
                  <strong>Reader</strong>
                  <small>Browse &amp; comment</small>
                </span>
              </label>
              <label class="role-card">
                <input type="radio" name="role" value="writer" />
                <span class="role-inner">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
                  <strong>Writer</strong>
                  <small>Publish posts</small>
                </span>
              </label>
            </div>
          </div>

          <button type="submit" class="btn-primary" id="submitBtn">
            <span class="btn-text">Create account</span>
            <span class="btn-loader" style="display:none">
              <svg class="spin" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>
            </span>
          </button>

          <div class="divider"><span>or continue with</span></div>

          <button type="button" class="btn-oauth">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
              <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
              <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
              <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
              <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
            </svg>
            Continue with Google
          </button>

          <p class="terms">
            By creating an account, you agree to our
            <a href="/terms">Terms of Service</a> and <a href="/privacy">Privacy Policy</a>.
          </p>

        </form>

        <p class="switch-link">
          Already have an account? <a href="/login">Sign in</a>
        </p>

      </div>
    </main>
  </div>

  <script src="/js/auth.js"></script>
</body>
</html>
